.project
.classpath
.settings/

# --- LOGS ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
log.txt

# --- SYSTEM FILES ---
.DS_Store
Thumbs.db
$RECYCLE.BIN/
ehthumbs.db
Desktop.ini

# --- SENSITIVE DATA (KEAMANAN) ---
