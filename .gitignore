# Abaikan aset web yang disalin oleh Capacitor (karena ini hasil build dari folder /www)
android/app/src/main/assets/public
ios/App/App/public

# --- IDE & EDITORS ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/
